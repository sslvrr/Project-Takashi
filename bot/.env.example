# ============================================================
# Project Takashi — Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# --- Trading Mode ---
MODE=PAPER                          # PAPER | LIVE

# --- Active Assets (comma-separated) ---
ACTIVE_ASSETS=XRP,EURUSD

# --- Coinbase Advanced Trade ---
# Get keys from: https://www.coinbase.com/settings/api (Advanced Trade section)
COINBASE_API_KEY=your_coinbase_api_key_name
COINBASE_SECRET=your_coinbase_private_key

# --- MetaTrader 5 ---
MT5_LOGIN=your_mt5_login
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_mt5_server

# --- PostgreSQL ---
DB_URL=postgresql://trader:secret@localhost:5432/trading
POSTGRES_USER=trader
POSTGRES_PASSWORD=secret
POSTGRES_DB=trading

# --- Telegram Alerts ---
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# --- Risk Parameters ---
MAX_DRAWDOWN=0.10                   # 10% portfolio kill switch
RISK_PER_TRADE=0.01                 # 1% equity per trade
MAX_DAILY_LOSS=0.05                 # 5% daily loss ceiling
MAX_CONCURRENT_POSITIONS=3

# --- Strategy Parameters ---
PANIC_DROP_THRESHOLD=-0.03          # -3% intraday drop triggers watch
RSI_OVERSOLD=30
VOLUME_SPIKE_MULTIPLIER=2.0
OB_IMBALANCE_THRESHOLD=0.60
MIN_SIGNAL_SCORE=5
TAKE_PROFIT_PCT=0.02                # 2%
STOP_LOSS_PCT=0.015                 # 1.5%

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000

# --- Dashboard ---
DASHBOARD_PORT=8501
